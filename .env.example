# ── Backend ────────────────────────────────────────────────────────────────────
# PostgreSQL + PostGIS connection string.
# Use postgresql:// (psycopg2 compatible). Do NOT prefix with +asyncpg.
DATABASE_URL=postgresql://postgres:password@localhost:5432/civic_tech

# Redis connection string.
REDIS_URL=redis://localhost:6379/0

# Comma-separated list of allowed CORS origins (no trailing slash).
# Example for local dev + production:
# ALLOWED_ORIGINS=http://localhost:3000,https://infra-up.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend (Next.js) ──────────────────────────────────────────────────────────
# Base URL of the FastAPI backend — used by all fetch() calls and the SSE stream.
# In production set this to your deployed API URL.
NEXT_PUBLIC_API_URL=http://localhost:8000
